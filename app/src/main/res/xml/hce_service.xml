<?xml version="1.0" encoding="utf-8"?>
<host-apdu-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/hce_description"
    android:requireDeviceUnlock="false"
    android:requireDeviceScreenOn="false">

    <!-- Only a placeholder AID is registered statically. The Salto AID is registered
         dynamically in onResume() and removed in onPause(), so JustIN Mobile handles
         door access normally whenever Un-Locker is not in the foreground. -->
    <aid-group
        android:category="other"
        android:description="@string/hce_description">
        <aid-filter android:name="F000000000" />
    </aid-group>

</host-apdu-service>
